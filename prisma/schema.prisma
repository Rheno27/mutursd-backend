generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ruangan {
  idRuangan         String              @id @map("id_ruangan") @db.VarChar(255)
  namaRuangan       String              @map("nama_ruangan") @db.VarChar(100)
  users             User[]
  bioPasien         BioPasien[]
  indikatorRuangan  IndikatorRuangan[]

  @@map("ruangan")
}

model Kategori {
  idKategori    Int             @id @default(autoincrement()) @map("id_kategori")
  kategori      String          @db.VarChar(100)
  indikatorMutu IndikatorMutu[]

  @@map("kategori")
}

model IndikatorMutu {
  idIndikator      Int                 @id @default(autoincrement()) @map("id_indikator")
  idKategori       Int                 @map("id_kategori")
  variabel         String              @db.Text
  standar          String              @db.Text
  kategori         Kategori            @relation(fields: [idKategori], references: [idKategori], onDelete: Restrict, onUpdate: Cascade)
  indikatorRuangan IndikatorRuangan[]

  @@map("indikator_mutu")
  @@index([idKategori], map: "fk_indikator_kategori")
}

model IndikatorRuangan {
  idIndikatorRuangan Int           @id @default(autoincrement()) @map("id_indikator_ruangan")
  idRuangan          String        @map("id_ruangan") @db.VarChar(255)
  idIndikator        Int           @map("id_indikator")
  active             Boolean
  ruangan            Ruangan       @relation(fields: [idRuangan], references: [idRuangan], onDelete: Restrict, onUpdate: Cascade)
  indikatorMutu      IndikatorMutu @relation(fields: [idIndikator], references: [idIndikator], onDelete: Restrict, onUpdate: Cascade)
  mutuRuangan        MutuRuangan[]

  @@map("indikator_ruangan")
  @@unique([idRuangan, idIndikator], map: "uq_indikator_ruangan_ruangan_indikator")
  @@index([idRuangan], map: "fk_indikator_ruangan")
  @@index([idIndikator], map: "fk_indikator_indikator")
  @@index([idRuangan, active])
  @@index([idRuangan, idIndikator, active])
}

model Pertanyaan {
  idPertanyaan    Int              @id @default(autoincrement()) @map("id_pertanyaan")
  pertanyaan      String           @db.VarChar(255)
  urutan          Int              @default(0)
  pilihanJawaban  PilihanJawaban[]
  jawaban         Jawaban[]

  @@map("pertanyaan")
}

model User {
  idUser       String   @id @map("id_user") @db.VarChar(255)
  username     String   @db.VarChar(50)
  password     String   @db.VarChar(255)
  idRuangan    String   @map("id_ruangan") @db.VarChar(255)
  namaRuangan  String   @map("nama_ruangan") @db.Text
  ruangan      Ruangan  @relation(fields: [idRuangan], references: [idRuangan], onDelete: Restrict, onUpdate: Cascade)

  @@map("user")
  @@index([idRuangan], map: "fk_user_ruangan")
  @@unique([username])
}

model BioPasien {
  idPasien       Int       @id @default(autoincrement()) @map("id_pasien")
  idRuangan      String    @map("id_ruangan") @db.VarChar(255)
  noRm           String    @map("no_rm") @db.VarChar(100)
  umur           Int
  jenisKelamin   String    @map("jenis_kelamin") @db.VarChar(50)
  pendidikan     String    @db.VarChar(50)
  pekerjaan      String    @db.VarChar(100)
  ruangan        Ruangan   @relation(fields: [idRuangan], references: [idRuangan], onDelete: Restrict, onUpdate: Cascade)
  jawaban        Jawaban[]

  @@map("bio_pasien")
  @@index([idRuangan], map: "fk_pasien_ruangan")
  @@index([noRm])
}

model PilihanJawaban {
  idPilihan       Int         @id @default(autoincrement()) @map("id_pilihan")
  idPertanyaan    Int         @map("id_pertanyaan")
  pilihan         String      @db.VarChar(255)
  nilai           Int
  pertanyaan      Pertanyaan  @relation(fields: [idPertanyaan], references: [idPertanyaan], onDelete: Restrict, onUpdate: Cascade)
  jawaban         Jawaban[]

  @@map("pilihan_jawaban")
  @@index([idPertanyaan], map: "fk_pilihan_pertanyaan")
}

model Jawaban {
  idJawaban       Int              @id @default(autoincrement()) @map("id_jawaban")
  tanggal         DateTime         @db.Date
  idPasien        Int              @map("id_pasien")
  idPertanyaan    Int              @map("id_pertanyaan")
  idPilihan       Int?             @map("id_pilihan")
  hasilNilai      String           @map("hasil_nilai") @db.Text
  pasien          BioPasien        @relation(fields: [idPasien], references: [idPasien], onDelete: Restrict, onUpdate: Cascade)
  pertanyaan      Pertanyaan       @relation(fields: [idPertanyaan], references: [idPertanyaan], onDelete: Restrict, onUpdate: Cascade)
  pilihanJawaban  PilihanJawaban?  @relation(fields: [idPilihan], references: [idPilihan], onDelete: SetNull, onUpdate: Cascade)

  @@map("jawaban")
  @@index([tanggal])
  @@index([idPasien], map: "fk_id_pasien")
  @@index([idPertanyaan], map: "fk_jawaban_pertanyaan")
  @@index([idPilihan], map: "fk_jawaban_pilihan")
}

model MutuRuangan {
  idMutu              Int               @id @default(autoincrement()) @map("id_mutu")
  tanggal             DateTime          @db.Date
  idIndikatorRuangan  Int               @map("id_indikator_ruangan")
  totalPasien         Int               @map("total_pasien")
  pasienSesuai        Int               @map("pasien_sesuai")
  indikatorRuangan    IndikatorRuangan  @relation(fields: [idIndikatorRuangan], references: [idIndikatorRuangan], onDelete: Restrict, onUpdate: Cascade)

  @@map("mutu_ruangan")
  @@unique([tanggal, idIndikatorRuangan], map: "uq_mutu_ruangan_tanggal_indikator")
  @@index([tanggal])
  @@index([idIndikatorRuangan], map: "fk_mutu_indikator")
  @@index([tanggal, idIndikatorRuangan])
}

model Session {
  id            String   @id @db.VarChar(255)
  userId        String?  @map("user_id") @db.VarChar(255)
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.Text
  payload       String   @db.LongText
  lastActivity  Int      @map("last_activity")

  @@map("sessions")
  @@index([userId], map: "sessions_user_id_index")
  @@index([lastActivity], map: "sessions_last_activity_index")
}
