{
  "name": "mutursd-backend",
  "version": "1.0.0",
  "description": "Express TypeScript backend for Mutu RSD",
  "main": "dist/index.js",
  "license": "ISC",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node src/index.ts",
    "ignore": [
      "dist/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "excel4node": "^1.8.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.10",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.14",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/node": "^18.11.3",
    "@types/pg": "^8.10.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4"
  }
}
