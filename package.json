{
  "name": "mutursd-backend",
  "version": "1.0.0",
  "description": "Express TypeScript backend for Mutu RSD",
  "type": "module",
  "main": "dist/src/index.js",
  "nodemonConfig": {
    "exec": "npx tsc && npm start",
    "watch": [
      "src/**/*.ts",
      "prisma/schema.prisma"
    ],
    "ext": "ts,prisma",
    "ignore": [
      "**/__tests__/**",
      "*.test.ts",
      "*.spec.ts",
      "dist/**"
    ]
  },
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/src/index.js",
    "dev": "nodemon",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "axios": "^1.1.3",
    "axios-curlirize": "1.3.7",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.45",
    "morgan-body": "^2.6.8",
    "nanoid": "^3.3.4",
    "reflect-metadata": "^0.1.13",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/axios-curlirize": "^1.3.2",
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.14",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^18.11.3",
    "concurrently": "^7.4.0",
    "nodemon": "^3.1.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4"
  }
}
